<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force www and https
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^(.*)$ https://peterwaweru.co.ke [R=301,L]

    # React Router fallback
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.html [L]
</IfModule>